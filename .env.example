# .env.example
# Server Configuration
PORT=3000
CONFIG_DIR=./data

# Security
# Set this to protect the admin/config endpoints
ADMIN_API_KEY=
# Set this to a strong secret to encrypt data at rest (conversations, config)
# If not set, it defaults to ADMIN_API_KEY for backwards compatibility
ENCRYPTION_SECRET=

# Local Provider Configuration
LOCAL_URL=http://localhost:11434
LOCAL_KEY=

# Cloud Provider Configuration (OpenAI Compatible)
CLOUD_URL=
CLOUD_API_KEY=

# Intent Router Configuration
# The model used to classify prompt intent and route to the right category
ROUTER_MODEL=
# Optional: Custom URL for the router (defaults to Local Provider URL if blank)
ROUTER_URL=
# Optional: Custom API key for the router endpoint
ROUTER_KEY=
